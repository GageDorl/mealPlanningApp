{
  "expo": {
    "name": "Prepd",
    "slug": "mealPlan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prepd",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.prepd.app",
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.prepd.app",
      "icon": "./assets/images/icon-dark.png",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icon-dark.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "@journeyapps/react-native-quick-sqlite",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Prepd to access the camera to scan barcodes."
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/984ecfa9-a0b7-487a-a054-4b4c34c011b1",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "984ecfa9-a0b7-487a-a054-4b4c34c011b1"
      }
    },
    "owner": "gagedorl"
  }
}
