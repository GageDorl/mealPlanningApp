{
  "cli": {
    "version": ">= 19.0.8",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "alpha": {
      "distribution": "internal",
      "channel": "alpha",
      "android": {
        "buildType": "apk"
      }
    },
    "beta": {
      "distribution": "internal",
      "channel": "beta-testing",
      "android": {
        "buildType": "apk"
      }
    },
    "play-alpha": {
      "channel": "alpha",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    },
    "play-beta": {
      "channel": "beta-testing",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    },
    "play-prod": {
      "channel": "prod",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
